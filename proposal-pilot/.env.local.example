# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# AI mode
# Use mock for local demos without API calls. Use live for Perplexity-backed testing.
AI_MODE=mock

# Perplexity AI — ONLY AI provider
# Covers Agent API, Sonar API, and Embeddings API
PERPLEXITY_API_KEY=your_key_here
